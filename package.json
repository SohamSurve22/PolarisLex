{
  "name": "asset-manager-workspace",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "backend/*",
    "frontend"
  ],
  "scripts": {
    "start": "npm run dev",
    "dev": "concurrently \"npm run dev -w @workspace/api-server\" \"npm run dev -w @workspace/polarislex\"",
    "build": "npm run build --workspaces --if-present",
    "test": "npm test --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  },
  "dependencies": {
    "sparse-bitfield": "^3.0.3"
  }
}
